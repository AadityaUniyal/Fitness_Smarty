# Frontend Environment Variables
# Copy this file to .env and fill in the values
# NOTE: All variables must start with VITE_ to be exposed to the browser in Vite

# === REQUIRED ===

# Google Gemini API key (get from https://aistudio.google.com/apikeys)
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# Backend API URL (change for production deployment)
VITE_API_URL=http://localhost:8000
VITE_API_BASE_URL=http://localhost:8000

# === OPTIONAL ===

# Clerk authentication (if using Clerk)
# CLERK_PUBLISHABLE_KEY=pk_live_...
