# Backend Environment Variables
# Copy this file to .env and fill in the values

# === REQUIRED ===

# Google Gemini API key (get from https://aistudio.google.com/apikeys)
GEMINI_API_KEY=your_gemini_api_key_here

# Database connection (SQLite used by default for local dev, PostgreSQL for production)
DATABASE_URL=sqlite:///./smarty_neural_core.db
# DATABASE_URL=postgresql://user:password@localhost:5432/smarty_db

# Secret key for JWT auth (generate with: openssl rand -hex 32)
SECRET_KEY=your-secret-key-here

# === OPTIONAL ===

# Comma-separated list of allowed CORS origins (defaults to localhost dev ports)
# CORS_ORIGINS=https://your-frontend-domain.com,https://www.your-frontend-domain.com

# Clerk authentication (if using Clerk for auth)
# CLERK_SECRET_KEY=sk_live_...
# CLERK_PUBLISHABLE_KEY=pk_live_...

# Separate training database (defaults to DATABASE_URL if not set)
# TRAINING_DATABASE_URL=postgresql://user:password@localhost:5432/smarty_training_db
